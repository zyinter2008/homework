.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #e8e8e8;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}

.tab-bar-item.active {
  color: #4F7CFF;
}

.tab-bar-item.active .tab-text {
  color: #4F7CFF;
  font-weight: 600;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 48rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 28rpx;
}

