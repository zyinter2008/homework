/* ========== 书包整理庆祝弹层 ========== */

.celebration-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 0.25s ease forwards;
}

.celebration-mask.show {
  opacity: 1;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.floating-star {
  position: fixed;
  top: -60rpx;
  z-index: 1001;
  animation: starFall 1.8s ease-out forwards;
  pointer-events: none;
}

@keyframes starFall {
  0% {
    transform: translateY(0) rotate(0deg) scale(0.3);
    opacity: 0;
  }
  15% {
    opacity: 1;
    transform: translateY(200rpx) rotate(60deg) scale(1.2);
  }
  50% {
    opacity: 1;
    transform: translateY(600rpx) rotate(180deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(1200rpx) rotate(360deg) scale(0.5);
  }
}

.celebration-card {
  z-index: 1002;
  background: linear-gradient(160deg, #FFF8E1, #ffffff, #FFF3E0);
  border: 3rpx solid #FFD54F;
  border-radius: 40rpx;
  padding: 60rpx 50rpx 50rpx;
  text-align: center;
  width: 580rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: cardBounceIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes cardBounceIn {
  0% {
    transform: scale(0.3) translateY(100rpx);
    opacity: 0;
  }
  60% {
    transform: scale(1.05) translateY(-10rpx);
    opacity: 1;
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

.celebration-emoji {
  font-size: 140rpx;
  line-height: 1.2;
  animation: emojiBounce 0.6s ease 0.2s both;
}

@keyframes emojiBounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.4); }
  70% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

.celebration-text {
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  margin-top: 20rpx;
  animation: textSlideUp 0.4s ease 0.3s both;
}

.celebration-sub {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF9800;
  margin-top: 16rpx;
  animation: textSlideUp 0.4s ease 0.45s both;
}

@keyframes textSlideUp {
  0% {
    transform: translateY(30rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.celebration-sub-done {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-top: 16rpx;
  animation: textSlideUp 0.4s ease 0.45s both;
}

.celebration-hint {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #bbb;
  animation: textSlideUp 0.3s ease 0.7s both;
}

/* 顶部卡片 */
.header-card {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #ffffff;
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
}

.header-emoji {
  font-size: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
}

.header-sub {
  font-size: 30rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* ========== 全局操作栏 ========== */
.global-action-bar {
  display: flex;
  justify-content: center;
  margin-bottom: -8rpx;
}

.global-unpack-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9800;
  background: #FFF3E0;
  padding: 16rpx 36rpx;
  border-radius: 28rpx;
  text-align: center;
  border: 2rpx solid #FFE0B2;
}

.global-unpack-btn:active {
  background: #FFE0B2;
}

/* ========== 新一天提示卡 ========== */
.new-day-card {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.new-day-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.new-day-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.new-day-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1565C0;
  margin-bottom: 6rpx;
}

.new-day-desc {
  font-size: 26rpx;
  color: #42A5F5;
  line-height: 1.5;
}

.new-day-close {
  font-size: 26rpx;
  color: #1565C0;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 20rpx;
  flex-shrink: 0;
  align-self: center;
}

.new-day-close:active {
  background: rgba(255,255,255,0.9);
}

/* ========== 分类卡片 ========== */
.category-card {
  border-radius: 24rpx;
  overflow: hidden;
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.category-left {
  display: flex;
  align-items: center;
}

.category-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.category-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.category-right {
  flex-shrink: 0;
}

.cat-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cat-bar-bg {
  width: 100rpx;
  height: 14rpx;
  background: #F0F0F0;
  border-radius: 7rpx;
  overflow: hidden;
}

.cat-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.cat-progress-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
  white-space: nowrap;
}

.cat-done-text {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 600;
  white-space: nowrap;
}

/* 分类批量操作 */
.category-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.cat-action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.cat-action-btn.pack-all {
  color: #4CAF50;
  background: #E8F5E9;
}

.cat-action-btn.pack-all:active {
  background: #C8E6C9;
}

.cat-action-btn.unpack-all {
  color: #FF9800;
  background: #FFF3E0;
}

.cat-action-btn.unpack-all:active {
  background: #FFE0B2;
}

/* ========== 物品列表 ========== */
.category-items {
  padding: 0;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.item-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.item-row:active {
  background: #F8F9FE;
}

.item-row.checked {
  opacity: 0.5;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-checkbox {
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid #E0E0E0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.check-placeholder {
  color: #ccc;
  font-size: 34rpx;
}

.item-checkbox.done {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-color: #4CAF50;
  animation: checkPop 0.25s ease;
}

@keyframes checkPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.25); }
  100% { transform: scale(1); }
}

.item-icon {
  font-size: 34rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.item-name {
  font-size: 34rpx;
  color: #333;
  word-break: break-all;
  white-space: normal;
}

.item-name.line-through {
  text-decoration: line-through;
  color: #aaa;
}

.item-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.pack-hint {
  font-size: 26rpx;
  color: #FF9800;
  background: #FFF3E0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.undo-pack-btn {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
  white-space: nowrap;
}

.undo-pack-btn:active {
  background: #f5f5f5;
  color: #FF9800;
  border-color: #FF9800;
}

.item-delete {
  color: #ccc;
  font-size: 34rpx;
  padding: 12rpx 16rpx;
  margin-left: 4rpx;
}

/* ========== 全部整理完 ========== */
.all-packed-card {
  text-align: center;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 48rpx 30rpx;
}

.all-packed-emoji {
  font-size: 80rpx;
}

.all-packed-text {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #2E7D32;
  margin-top: 16rpx;
}

.all-packed-hint {
  display: block;
  font-size: 30rpx;
  color: #66BB6A;
  margin-top: 8rpx;
}

.next-step-btn {
  margin-top: 28rpx;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  color: #E65100;
  font-weight: 600;
}

.next-step-btn:active {
  opacity: 0.85;
}

.next-step-done {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  color: #2E7D32;
  font-weight: 600;
}

.star-reward-tag {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #F57F17;
}

.repack-hint {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #81C784;
  line-height: 1.6;
}

.repack-btn {
  margin-top: 20rpx;
  display: inline-block;
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.empty-main {
  display: block;
  font-size: 34rpx;
  color: #999;
}

.empty-hint {
  display: block;
  font-size: 28rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* ========== 分区标题 ========== */
.section-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.section-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.toggle-link {
  margin-left: auto;
  font-size: 28rpx;
  color: #4F7CFF;
  font-weight: 400;
  padding: 8rpx 16rpx;
}

/* ========== 一键推荐配置 ========== */
.preset-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.preset-card:active {
  opacity: 0.85;
}

.preset-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.preset-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.preset-text {
  display: flex;
  flex-direction: column;
}

.preset-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1565C0;
}

.preset-desc {
  font-size: 24rpx;
  color: #64B5F6;
  margin-top: 4rpx;
}

.preset-arrow {
  font-size: 36rpx;
  color: #1565C0;
  font-weight: 700;
  flex-shrink: 0;
}

/* ========== 分隔线 ========== */
.quick-divider {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E0E0E0;
}

.divider-text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* ========== 目标书袋选择 ========== */
.target-section {
  margin-bottom: 20rpx;
}

.target-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.target-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 4rpx 0;
}

.target-tab {
  display: inline-block;
  font-size: 26rpx;
  padding: 14rpx 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #E0E0E0;
  color: #666;
  background: #F8F8F8;
  white-space: nowrap;
  font-weight: 600;
  transition: all 0.2s ease;
}

.target-tab.active {
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

/* ========== 快捷添加 ========== */
.quick-add-area {
  margin-top: 8rpx;
}

.quick-group {
  margin-bottom: 24rpx;
}

.quick-group:last-child {
  margin-bottom: 0;
}

.quick-group-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-tag {
  display: flex;
  align-items: center;
  background: #F0F4FF;
  color: #4F7CFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid #D6E4FF;
}

.tag-icon {
  margin-right: 6rpx;
  font-size: 30rpx;
}

.quick-tag:active {
  background: #D6E4FF;
}

.quick-tag.added {
  background: #F5F5F5;
  color: #bbb;
  border-color: #eee;
}

.tag-check {
  color: #4CAF50;
}

/* ========== 自定义添加 ========== */
.add-item-btn {
  text-align: center;
  padding: 28rpx;
  color: #666;
  font-size: 32rpx;
  border: 2rpx dashed #ccc;
  border-radius: 16rpx;
}

.add-item-form {
  padding: 0;
}

.form-row {
  margin-bottom: 16rpx;
}

.category-picker-wrap {
  width: 100%;
}

.category-picker {
  background: #F0F4FF;
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.item-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 32rpx;
  background: #F9F9F9;
}

.form-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-small {
  flex: 1;
  font-size: 30rpx;
  padding: 18rpx 0;
  border-radius: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-confirm {
  background: #FF9800;
  color: #fff;
}

.btn-cancel {
  background: #F0F0F0;
  color: #666;
}

/* ========== 底部提示 ========== */
.footer-hint {
  text-align: center;
  padding: 20rpx 0 8rpx;
  font-size: 26rpx;
  color: #bbb;
}

.footer-hint-sub {
  padding-bottom: 40rpx;
}
