/* 锁定页 */
.lock-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.lock-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.lock-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.lock-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.pin-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 36rpx;
  text-align: center;
  letter-spacing: 20rpx;
  background: #F9F9F9;
}

/* 导航标签 */
.nav-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow-x: auto;
  white-space: nowrap;
}

.nav-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  color: #666;
  transition: all 0.2s;
  min-width: 0;
}

.nav-tab.active {
  background: #4F7CFF;
  color: #fff;
  font-weight: 600;
}

/* 区域描述 */
.section-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

/* 评价相关 */
.review-tasks {
  padding: 10rpx 0;
}

.review-task-item {
  padding: 10rpx 0;
  font-size: 28rpx;
}

.review-info {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
}

.review-prompt {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin: 20rpx 0 16rpx;
}

.review-btns {
  display: flex;
  gap: 16rpx;
}

.review-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  line-height: 1.5;
}

.review-btn::after {
  border: none;
}

.review-btn.good {
  background: #E8F5E9;
  color: #2E7D32;
}

.review-btn.ok {
  background: #FFF3E0;
  color: #E65100;
}

.review-btn.bad {
  background: #FFEBEE;
  color: #C62828;
}

.review-btn.small {
  padding: 12rpx 0;
  font-size: 32rpx;
}

.review-result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
}

.reviewed-label {
  font-size: 26rpx;
  color: #666;
}

.reviewed-value {
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

.reviewed-value.good { color: #2E7D32; }
.reviewed-value.ok { color: #E65100; }
.reviewed-value.bad { color: #C62828; }

.re-review-tip {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 预设任务 */
.preset-list {
  margin-bottom: 20rpx;
}

.preset-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 16rpx;
  background: #F5F7FA;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.preset-name {
  font-size: 28rpx;
  color: #333;
}

.preset-delete {
  color: #999;
  font-size: 28rpx;
  padding: 4rpx 12rpx;
}

.add-preset-form {
  margin-bottom: 20rpx;
}

.task-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
}

.btn-small {
  font-size: 26rpx;
  padding: 14rpx 0;
  border-radius: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-confirm {
  background: #4F7CFF;
  color: #fff;
}

/* 礼品管理 */
.gift-manage-list {
  margin-bottom: 10rpx;
}

.gift-manage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.gift-manage-item:last-child {
  border-bottom: none;
}

.gift-manage-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.gift-manage-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.gift-manage-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.action-btn.edit {
  background: #E8F0FE;
  color: #4F7CFF;
}

.action-btn.delete {
  background: #FFEBEE;
  color: #F44336;
}

.add-gift-toggle {
  text-align: center;
  color: #4F7CFF;
  font-size: 28rpx;
  padding: 16rpx;
  font-weight: 600;
}

.gift-form {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.form-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
}

/* 库存预警 */
.stock-warning {
  padding: 16rpx 20rpx;
  background: #FFF3E0;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #E65100;
  margin-top: 12rpx;
}

.stock-danger {
  padding: 16rpx 20rpx;
  background: #FFEBEE;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #C62828;
  margin-top: 12rpx;
}

/* 兑换交付 */
.deliver-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.deliver-item:last-child {
  border-bottom: none;
}

.deliver-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.deliver-detail {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.deliver-btn {
  background: #4F7CFF;
  color: #fff;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: none;
  line-height: 1.5;
  flex-shrink: 0;
}

.deliver-btn::after {
  border: none;
}

.delivered-tag {
  font-size: 26rpx;
  color: #4CAF50;
  flex-shrink: 0;
}

/* 内容管理 */
.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin: 16rpx 0 12rpx;
}

.content-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.content-item:last-child {
  border-bottom: none;
}

.content-item-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.content-item-detail {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.form-picker {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
  color: #333;
}

.form-textarea {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
  width: 100%;
  min-height: 240rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

.form-item-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.form-item.half {
  flex: 1;
  margin-bottom: 0;
}

/* 使用说明 */
.tips-card {
  background: #FFFDE7;
}

.tip-list {
  padding: 0;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  padding: 6rpx 0;
}

