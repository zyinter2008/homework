<view class="container">
  <!-- 打卡庆祝弹层 -->
  <view class="celebration-mask {{showCelebration ? 'show' : ''}}" wx:if="{{showCelebration}}" catchtap="onMaskTap">
    <!-- 飞散的星星 -->
    <view
      wx:for="{{celebrationStars}}"
      wx:key="id"
      class="floating-star"
      style="left: {{item.left}}%; animation-delay: {{item.delay}}ms; font-size: {{item.size}}rpx;"
    >{{item.emoji}}</view>

    <!-- 主内容 -->
    <view class="celebration-card {{celebrationType}}" catchtap="onCardTap">
      <view class="celebration-emoji">{{celebrationEmoji}}</view>
      <view class="celebration-text">{{celebrationText}}</view>
      <view class="celebration-sub">{{celebrationSub}}</view>

      <!-- 全部完成的操作按钮 -->
      <view class="celebration-actions" wx:if="{{celebrationType === 'allDone'}}">
        <view class="celebration-btn primary" bindtap="onCelebrationGoChecklist">
          <text>🎒 检查明天的书包</text>
        </view>
        <view class="celebration-btn ghost" bindtap="onDismissCelebration">
          <text>稍后再看</text>
        </view>
      </view>

      <!-- 单项完成的点击提示 -->
      <view class="celebration-hint" wx:if="{{celebrationType === 'task'}}">
        <text>点击任意处关闭</text>
      </view>
    </view>
  </view>

  <!-- 顶部状态栏 -->
  <view class="header-card card">
    <view class="header-top">
      <view class="date-info">
        <text class="date-text">📅 {{todayDisplay}}</text>
      </view>
      <view class="star-badge" bindtap="goStars">
        <text class="star-count">⭐ {{totalStars}}</text>
      </view>
    </view>
    <view class="greeting" wx:if="{{dailyData}}">
      <text wx:if="{{allCompleted}}" class="greeting-done">🎉 今日作业全部完成！</text>
      <text wx:elif="{{dailyData.tasks.length === 0}}" class="greeting-empty">还没有设置今天的任务哦</text>
      <text wx:elif="{{completedCount > 0}}" class="greeting-todo">已完成 {{completedCount}} 项，继续加油！</text>
      <text wx:else class="greeting-todo">加油完成今天的作业吧！</text>
    </view>
  </view>

  <!-- 今日任务列表 -->
  <view class="card" wx:if="{{dailyData && dailyData.tasks.length > 0}}">
    <view class="card-title">
      <text>📋</text>
      <text>今日任务</text>
      <view class="task-progress">
        <text class="progress-text">{{completedCount}}/{{totalCount}}</text>
      </view>
    </view>

    <!-- 进度条 -->
    <view class="progress-bar-wrap">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
    </view>

    <!-- 任务列表 -->
    <view class="task-list">
      <view
        wx:for="{{dailyData.tasks}}"
        wx:key="id"
        class="task-item {{item.completed ? 'completed' : ''}}"
      >
        <view class="task-left">
          <view class="task-status {{item.completed ? 'done' : ''}}">
            <text wx:if="{{item.completed}}">⭐</text>
            <text wx:else>○</text>
          </view>
          <view class="task-title {{item.completed ? 'line-through' : ''}}">{{item.title}}</view>
        </view>
        <view class="task-right">
          <view wx:if="{{!item.completed}}" class="checkin-task-btn" bindtap="onCheckInTask" data-id="{{item.id}}">
            <text>打卡 +1⭐</text>
          </view>
          <view wx:if="{{item.completed}}" class="task-done-tag">
            <text>已完成</text>
          </view>
          <view wx:if="{{item.completed}}" class="undo-btn" bindtap="onUndoCheckIn" data-id="{{item.id}}">
            <text>撤销</text>
          </view>
          <view class="task-delete" bindtap="onDeleteTask" data-id="{{item.id}}" wx:if="{{!item.completed}}">✕</view>
        </view>
      </view>
    </view>

    <!-- 全部完成提示 -->
    <view class="all-done-banner" wx:if="{{allCompleted}}">
      <text>🏆 全部完成！额外获得 +3⭐ 奖励</text>
    </view>

    <!-- 添加任务 -->
    <view wx:if="{{!allCompleted}}">
      <view class="add-task-btn" bindtap="showAddTask" wx:if="{{!showAddTask}}">
        <text>+ 添加今日任务</text>
      </view>
      <view class="add-task-form" wx:if="{{showAddTask}}">
        <input
          class="task-input"
          placeholder="输入任务名称"
          value="{{newTaskName}}"
          bindinput="onTaskNameInput"
          confirm-type="done"
          bindconfirm="addTask"
        />
        <view class="form-btns">
          <button class="btn-small btn-confirm" bindtap="addTask">添加</button>
          <button class="btn-small btn-cancel" bindtap="hideAddTask">取消</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="card" wx:if="{{dailyData && dailyData.tasks.length === 0}}">
    <view class="empty-state">
      <view class="icon">📝</view>
      <text>今天还没有任务</text>
      <view style="margin-top: 20rpx;">
        <button class="btn-primary" bindtap="showAddTask">添加任务</button>
      </view>
      <view wx:if="{{showAddTask}}" class="add-task-form" style="margin-top: 30rpx;">
        <input
          class="task-input"
          placeholder="输入任务名称"
          value="{{newTaskName}}"
          bindinput="onTaskNameInput"
          confirm-type="done"
          bindconfirm="addTask"
        />
        <view class="form-btns">
          <button class="btn-small btn-confirm" bindtap="addTask">添加</button>
          <button class="btn-small btn-cancel" bindtap="hideAddTask">取消</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 打卡后状态 -->
  <view class="card" wx:if="{{dailyData && dailyData.checkedIn}}">
    <view class="card-title">
      <text>🏆</text>
      <text>今日打卡记录</text>
    </view>
    <view class="checkin-info">
      <view class="info-row">
        <text class="info-label">完成时间</text>
        <text class="info-value">{{dailyData.checkedInTime}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">获得星星</text>
        <view class="info-value">
          <text>{{totalCount}} + 3 = {{totalCount + 3}}⭐</text>
        </view>
      </view>
      <view class="info-row" wx:if="{{dailyData.parentReviewed}}">
        <text class="info-label">家长评价</text>
        <text class="info-value {{dailyData.starsEarned.parentReview > 0 ? 'text-green' : (dailyData.starsEarned.parentReview < 0 ? 'text-red' : '')}}">
          {{dailyData.starsEarned.parentReview > 0 ? '优秀 👍' : (dailyData.starsEarned.parentReview < 0 ? '待改进 💪' : '合格 ✅')}}
        </text>
      </view>
      <view class="info-row" wx:if="{{!dailyData.parentReviewed}}">
        <text class="info-label">家长评价</text>
        <text class="info-value text-orange">等待家长检查</text>
      </view>
    </view>

    <!-- 推荐阅读入口 -->
    <view wx:if="{{dailyData.recommendShown && !dailyData.recommendCompleted}}" class="recommend-entry" bindtap="goRecommend">
      <text>📚 去完成推荐阅读，再得1颗星 →</text>
    </view>
    <view wx:if="{{dailyData.recommendCompleted}}" class="recommend-done">
      <text>📚 推荐阅读已完成 ✅</text>
    </view>
  </view>

  <!-- 书包整理入口 -->
  <view class="checklist-entry card {{allCompleted && checklistUnchecked > 0 ? 'highlight' : ''}}" bindtap="goChecklist">
    <view class="checklist-entry-content">
      <view class="checklist-icon">🎒</view>
      <view class="checklist-info">
        <text class="checklist-title">明天要带的东西</text>
        <text class="checklist-desc" wx:if="{{checklistTotal === 0}}">点击添加明天要带的物品</text>
        <text class="checklist-desc ok" wx:elif="{{checklistAllDone}}">全部装好了 ✅</text>
        <text class="checklist-desc warn" wx:else>还有 {{checklistUnchecked}} 样东西没装</text>
      </view>
      <view class="checklist-badge" wx:if="{{checklistUnchecked > 0}}">
        <text>{{checklistUnchecked}}</text>
      </view>
      <view class="checklist-arrow" wx:else>→</view>
    </view>
  </view>
</view>
