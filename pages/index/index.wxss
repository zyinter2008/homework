/* 顶部卡片 */
.header-card {
  background: linear-gradient(135deg, #4F7CFF, #6B8FFF);
  color: #ffffff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.star-badge {
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.star-count {
  font-size: 28rpx;
  font-weight: 600;
}

.greeting {
  margin-top: 8rpx;
}

.greeting-done {
  font-size: 36rpx;
  font-weight: 700;
}

.greeting-empty {
  font-size: 30rpx;
  opacity: 0.8;
}

.greeting-todo {
  font-size: 30rpx;
  font-weight: 600;
}

/* 任务进度 */
.task-progress {
  margin-left: auto;
}

.progress-text {
  font-size: 26rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.progress-bar-wrap {
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: #E8F0FE;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F7CFF, #66BB6A);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 任务列表 */
.task-list {
  margin-bottom: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.completed {
  opacity: 0.7;
}

.task-check {
  margin-right: 20rpx;
  padding: 4rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #CCCCCC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-color: #4CAF50;
}

.task-title {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.task-title.line-through {
  text-decoration: line-through;
  color: #999;
}

.task-delete {
  color: #ccc;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

/* 添加任务 */
.add-task-btn {
  text-align: center;
  padding: 20rpx;
  color: #4F7CFF;
  font-size: 28rpx;
  border: 2rpx dashed #4F7CFF;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.add-task-form {
  margin-top: 12rpx;
}

.task-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
}

.form-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-small {
  flex: 1;
  font-size: 26rpx;
  padding: 14rpx 0;
  border-radius: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-confirm {
  background: #4F7CFF;
  color: #fff;
}

.btn-cancel {
  background: #F0F0F0;
  color: #666;
}

/* 打卡按钮 */
.checkin-section {
  margin: 30rpx 0;
}

.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn.active {
  background: linear-gradient(135deg, #FF6B35, #FF8F60);
  color: #ffffff;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.4);
  animation: pulse 2s infinite;
}

.checkin-btn.disabled {
  background: #E0E0E0;
  color: #999;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.02); }
  100% { transform: scale(1); }
}

.checkin-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.checkin-text {
  font-size: 32rpx;
}

/* 打卡后信息 */
.checkin-info {
  padding: 10rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  color: #666;
  font-size: 28rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.text-green { color: #4CAF50; }
.text-red { color: #F44336; }
.text-orange { color: #FF9800; }

/* 推荐入口 */
.recommend-entry {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #E65100;
  font-weight: 600;
}

.recommend-done {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
}

