/* ========== 打卡庆祝弹层 ========== */

.celebration-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 0.25s ease forwards;
}

.celebration-mask.show {
  opacity: 1;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 飞散星星 */
.floating-star {
  position: fixed;
  top: -60rpx;
  z-index: 1001;
  animation: starFall 1.8s ease-out forwards;
  pointer-events: none;
}

@keyframes starFall {
  0% {
    transform: translateY(0) rotate(0deg) scale(0.3);
    opacity: 0;
  }
  15% {
    opacity: 1;
    transform: translateY(200rpx) rotate(60deg) scale(1.2);
  }
  50% {
    opacity: 1;
    transform: translateY(600rpx) rotate(180deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(1200rpx) rotate(360deg) scale(0.5);
  }
}

/* 庆祝卡片 */
.celebration-card {
  z-index: 1002;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 60rpx 50rpx 50rpx;
  text-align: center;
  width: 580rpx;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: cardBounceIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.celebration-card.allDone {
  background: linear-gradient(160deg, #FFF8E1, #ffffff, #FFF3E0);
  border: 3rpx solid #FFD54F;
}

@keyframes cardBounceIn {
  0% {
    transform: scale(0.3) translateY(100rpx);
    opacity: 0;
  }
  60% {
    transform: scale(1.05) translateY(-10rpx);
    opacity: 1;
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

.celebration-emoji {
  font-size: 120rpx;
  line-height: 1.2;
  animation: emojiBounce 0.6s ease 0.2s both;
}

.allDone .celebration-emoji {
  font-size: 140rpx;
  animation: emojiSpin 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.2s both;
}

@keyframes emojiBounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.4); }
  70% { transform: scale(0.9); }
  100% { transform: scale(1); }
}

@keyframes emojiSpin {
  0% { transform: scale(0) rotate(-180deg); }
  60% { transform: scale(1.3) rotate(10deg); }
  80% { transform: scale(0.95) rotate(-5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.celebration-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  margin-top: 20rpx;
  animation: textSlideUp 0.4s ease 0.3s both;
}

.allDone .celebration-text {
  font-size: 48rpx;
  background: linear-gradient(135deg, #FF6B35, #FF3D00);
  -webkit-background-clip: text;
  color: transparent;
}

.celebration-sub {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  margin-top: 16rpx;
  animation: textSlideUp 0.4s ease 0.45s both;
}

.allDone .celebration-sub {
  font-size: 40rpx;
  color: #FF6B35;
}

@keyframes textSlideUp {
  0% {
    transform: translateY(30rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.celebration-hint {
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #bbb;
  animation: textSlideUp 0.3s ease 0.7s both;
}

/* 全部完成的操作按钮 */
.celebration-actions {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  animation: textSlideUp 0.4s ease 0.5s both;
}

.celebration-btn {
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.celebration-btn.primary {
  background: linear-gradient(135deg, #4F7CFF, #6B8FFF);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(79, 124, 255, 0.35);
}

.celebration-btn.secondary {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: #E65100;
  border: 2rpx solid #FFB74D;
}

.celebration-btn.ghost {
  background: transparent;
  color: #999;
  font-size: 26rpx;
  font-weight: 400;
  padding: 12rpx 0;
}

/* ========== 页面主体 ========== */

/* 顶部卡片 */
.header-card {
  background: linear-gradient(135deg, #4F7CFF, #6B8FFF);
  color: #ffffff;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.star-badge {
  background: rgba(255, 255, 255, 0.25);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.star-count {
  font-size: 28rpx;
  font-weight: 600;
}

.greeting {
  margin-top: 8rpx;
}

.greeting-done {
  font-size: 36rpx;
  font-weight: 700;
}

.greeting-empty {
  font-size: 30rpx;
  opacity: 0.8;
}

.greeting-todo {
  font-size: 30rpx;
  font-weight: 600;
}

/* 任务进度 */
.task-progress {
  margin-left: auto;
}

.progress-text {
  font-size: 26rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.progress-bar-wrap {
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 12rpx;
  background: #E8F0FE;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F7CFF, #66BB6A);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 任务列表 */
.task-list {
  margin-bottom: 16rpx;
}

.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.completed {
  opacity: 0.75;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.task-status {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-status.done {
  animation: starPop 0.3s ease;
}

@keyframes starPop {
  0% { transform: scale(0.5); }
  60% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.task-title {
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-title.line-through {
  text-decoration: line-through;
  color: #999;
}

.task-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.checkin-task-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8F60);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  white-space: nowrap;
}

.checkin-task-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.task-done-tag {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 600;
  padding: 10rpx 16rpx;
  background: #E8F5E9;
  border-radius: 20rpx;
  white-space: nowrap;
}

.undo-btn {
  font-size: 22rpx;
  color: #999;
  padding: 6rpx 16rpx;
  margin-left: 8rpx;
  border: 1rpx solid #ddd;
  border-radius: 16rpx;
  white-space: nowrap;
}

.undo-btn:active {
  background: #f5f5f5;
  color: #F44336;
  border-color: #F44336;
}

.task-delete {
  color: #ccc;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

/* 全部完成横幅 */
.all-done-banner {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #F57F17;
  font-weight: 700;
}

/* 添加任务 */
.add-task-btn {
  text-align: center;
  padding: 20rpx;
  color: #4F7CFF;
  font-size: 28rpx;
  border: 2rpx dashed #4F7CFF;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.add-task-form {
  margin-top: 12rpx;
}

.task-input {
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #F9F9F9;
}

.form-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-small {
  flex: 1;
  font-size: 26rpx;
  padding: 14rpx 0;
  border-radius: 30rpx;
  text-align: center;
  line-height: 1.5;
}

.btn-confirm {
  background: #4F7CFF;
  color: #fff;
}

.btn-cancel {
  background: #F0F0F0;
  color: #666;
}

/* 打卡后信息 */
.checkin-info {
  padding: 10rpx 0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  color: #666;
  font-size: 28rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.text-green { color: #4CAF50; }
.text-red { color: #F44336; }
.text-orange { color: #FF9800; }

/* 推荐入口 */
.recommend-entry {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #E65100;
  font-weight: 600;
}

.recommend-done {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
}

/* 书包整理入口 */
.checklist-entry {
  transition: all 0.3s ease;
}

.checklist-entry.highlight {
  background: linear-gradient(135deg, #FFF8E1, #FFF3E0);
  border: 2rpx solid #FFB74D;
  animation: gentlePulse 2s ease-in-out infinite;
}

@keyframes gentlePulse {
  0%, 100% { box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.15); }
  50% { box-shadow: 0 6rpx 24rpx rgba(255, 152, 0, 0.35); }
}

.checklist-entry-content {
  display: flex;
  align-items: center;
}

.checklist-icon {
  font-size: 52rpx;
  margin-right: 20rpx;
}

.checklist-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.checklist-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.checklist-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.checklist-desc.warn {
  color: #FF9800;
  font-weight: 600;
}

.checklist-desc.ok {
  color: #4CAF50;
  font-weight: 600;
}

.checklist-badge {
  background: #FF5722;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checklist-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}
