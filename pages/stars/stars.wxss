/* 星星总览 */
.star-overview {
  text-align: center;
  background: linear-gradient(135deg, #FFA726, #FFB74D);
  color: #fff;
  padding: 50rpx 30rpx;
}

.star-big {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.star-emoji {
  font-size: 60rpx;
  margin-right: 16rpx;
}

.star-total {
  font-size: 80rpx;
  font-weight: 800;
}

.star-label {
  font-size: 28rpx;
  opacity: 0.9;
}

.today-earned {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.25);
  display: inline-block;
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 规则 */
.rules-card {
  background: #FFFDE7;
}

.rule-list {
  padding: 0;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 48rpx;
  text-align: center;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #555;
}

.rule-stars {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 600;
}

/* 历史记录 */
.history-group {
  margin-bottom: 24rpx;
}

.history-group:last-child {
  margin-bottom: 0;
}

.history-date {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 2rpx solid #E8E8E8;
}

.history-total {
  font-size: 26rpx;
}

.history-total.positive {
  color: #4CAF50;
}

.history-total.negative {
  color: #F44336;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0 14rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.history-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  width: 100rpx;
}

.record-reason {
  flex: 1;
  font-size: 26rpx;
  color: #555;
}

.record-amount {
  font-size: 28rpx;
  font-weight: 700;
  width: 60rpx;
  text-align: right;
}

.record-amount.positive {
  color: #4CAF50;
}

.record-amount.negative {
  color: #F44336;
}

