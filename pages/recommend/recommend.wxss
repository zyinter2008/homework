/* 头部 */
.header-card {
  background: linear-gradient(135deg, #7B1FA2, #9C27B0);
  color: #fff;
}

.header-content {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-emoji {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.85;
  display: block;
  margin-top: 4rpx;
}

.header-tip {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 26rpx;
}

/* 推荐卡片 */
.recommend-card {
  transition: all 0.3s ease;
  border-left: 6rpx solid #E0E0E0;
}

.recommend-card.read {
  border-left-color: #4CAF50;
  background: #FAFFF9;
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-badge {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.type-badge.book {
  background: #E3F2FD;
  color: #1565C0;
}

.type-badge.video {
  background: #FCE4EC;
  color: #C62828;
}

.duration {
  font-size: 24rpx;
  color: #999;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.recommend-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 操作区域 - 进入阅读/观看 */
.recommend-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #E8F0FE, #F0F4FF);
  border-radius: 12rpx;
  border: 2rpx solid #D0DCFF;
}

.action-text {
  font-size: 28rpx;
  color: #4F7CFF;
  font-weight: 600;
}

.action-arrow {
  font-size: 32rpx;
  color: #4F7CFF;
  font-weight: 700;
}

/* 已完成状态 */
.recommend-done {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
}

.done-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.done-text {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 600;
  flex: 1;
}

.redo-link {
  padding: 6rpx 16rpx;
  background: rgba(46, 125, 50, 0.1);
  border-radius: 16rpx;
}

.redo-link text {
  font-size: 24rpx;
  color: #2E7D32;
}

/* 完成按钮 */
.complete-section {
  margin: 30rpx 0;
}

.complete-btn {
  padding: 28rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  border: none;
}

.complete-btn::after {
  border: none;
}

.complete-btn.active {
  background: linear-gradient(135deg, #FF6B35, #FF8F60);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.4);
}

.complete-btn.disabled {
  background: #E0E0E0;
  color: #999;
}

/* 返回链接 */
.back-link {
  text-align: center;
  padding: 20rpx;
  color: #4F7CFF;
  font-size: 28rpx;
}
