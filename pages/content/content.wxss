/* 信息栏 */
.info-bar {
  background: linear-gradient(135deg, #7B1FA2, #9C27B0);
  color: #fff;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-badge {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

.duration {
  font-size: 24rpx;
  opacity: 0.85;
}

.content-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.content-desc {
  font-size: 26rpx;
  opacity: 0.85;
  display: block;
  margin-bottom: 16rpx;
}

.read-timer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
}

.timer-text {
  font-size: 24rpx;
}

.timer-status {
  font-size: 24rpx;
  opacity: 0.8;
}

.timer-status.done {
  opacity: 1;
  font-weight: 600;
}

/* ===== 电子书阅读器 ===== */
.reader-card {
  padding: 0;
  overflow: hidden;
}

/* 拼音/普通模式切换 */
.mode-toggle {
  text-align: center;
  padding: 16rpx;
  background: #F0F4FF;
  font-size: 24rpx;
  color: #4F7CFF;
  font-weight: 600;
  border-bottom: 1rpx solid #E0E8FF;
}

.book-reader {
  height: 800rpx;
  padding: 32rpx;
}

/* 拼音内容 */
.pinyin-content {
  padding-bottom: 40rpx;
}

.pinyin-line {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  margin-bottom: 12rpx;
  line-height: 1;
}

.py-char {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 4rpx 2rpx;
}

.py-top {
  font-size: 18rpx;
  color: #999;
  line-height: 1.4;
  font-family: 'PingFang SC', sans-serif;
}

.py-bottom {
  font-size: 34rpx;
  color: #333;
  line-height: 1.5;
}

.py-plain {
  font-size: 34rpx;
  color: #333;
  line-height: 1.5;
  margin: 4rpx 0;
  align-self: flex-end;
}

/* 普通文本 */
.book-content {
  line-height: 1.9;
}

.paragraph {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.paragraph-gap {
  height: 24rpx;
}

/* ===== 视频播放器 ===== */
.player-card {
  padding: 0;
  overflow: hidden;
  border-radius: 20rpx;
}

.video-wrap {
  width: 100%;
}

.video-player {
  width: 100%;
  height: 420rpx;
}

/* B站/外部链接视频 */
.link-video {
  text-align: center;
  padding: 50rpx 40rpx;
}

.link-video-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.link-video-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.link-video-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
}

.bilibili-badge {
  display: inline-block;
  background: linear-gradient(135deg, #FB7299, #FC9DB7);
  color: #fff;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.link-tip {
  background: #F5F7FA;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: left;
  margin-bottom: 24rpx;
}

.tip-main {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tip-detail {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.copy-link-btn {
  background: linear-gradient(135deg, #4F7CFF, #6B8FFF);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}

.copy-link-btn::after {
  border: none;
}

.link-url {
  background: #F5F5F5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  word-break: break-all;
}

.link-url text {
  font-size: 22rpx;
  color: #999;
}

/* 未配置视频 */
.no-video {
  text-align: center;
  padding: 60rpx 40rpx;
  background: #F5F5F5;
}

.no-video-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-video-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.no-video-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

.no-video-tip {
  background: #FFF3E0;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: left;
}

.no-video-tip text {
  display: block;
  font-size: 26rpx;
  color: #E65100;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.no-video-tip .tip-detail {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-bar {
  margin-top: 30rpx;
  padding-bottom: 40rpx;
}

.done-btn {
  padding: 28rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  border: none;
}

.done-btn::after {
  border: none;
}

.done-btn.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.4);
}

.done-btn.disabled {
  background: #E0E0E0;
  color: #999;
}

.back-link {
  text-align: center;
  padding: 24rpx;
  color: #4F7CFF;
  font-size: 28rpx;
}
